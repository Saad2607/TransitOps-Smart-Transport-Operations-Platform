{
  "name": "transitops-backend",
  "version": "1.0.0",
  "description": "TransitOps Smart Transport Operations Platform — Backend API",
  "main": "server.js",
  "scripts": {
    "db:init": "psql -U postgres -d transitops -f database/schema.sql && psql -U postgres -d transitops -f database/seed.sql",
    "db:migrate": "psql -U postgres -d transitops -f database/migrations/002_indexes_and_constraints.sql",
    "db:migrate:analytics": "psql -U postgres -d transitops -f database/migrations/003_analytics_aggregations.sql",
    "db:migrate:all": "node scripts/run-migrations.js",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:auth": "node ../tests/phase1-auth.test.js",
    "test:assets": "node ../tests/phase2-assets.test.js",
    "test:trips": "node ../tests/phase3-trips.test.js",
    "test:full-system": "node ../tests/phase4-full-system.test.js"
  },
  "keywords": [
    "transitops",
    "fleet-management",
    "postgresql"
  ],
  "author": "TransitOps Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
