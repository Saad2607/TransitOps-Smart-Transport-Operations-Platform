# PostgreSQL (use DATABASE_URL on Render/Railway, or individual vars locally)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transitops
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000

# Debug
DB_LOG_QUERIES=false

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# First cloud deploy only — creates admin user from seed.sql
RUN_SEED=false

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=8h
JWT_ISSUER=transitops-api
